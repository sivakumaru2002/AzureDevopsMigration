# Azure DevOps source
AZDO_SOURCE_PAT=your-source-pat-here
AZDO_SOURCE_ORG=your-source-org-name
AZDO_SOURCE_PROJECT=optional-source-project-name

# Azure DevOps target
AZDO_TARGET_PAT=your-target-pat-here
AZDO_TARGET_ORG=your-target-org-name
AZDO_TARGET_PROJECT=optional-target-project-name

# Azure DevOps base URL
AZDO_BASE_URL=https://dev.azure.com

# Notes:
# - This single .env file is used by both migrate_azure_devops_repos.py and the configuration.json renderer.
# - Keep organization values as short names, for example: sivakumaru
# - run_all_migrations.sh renders configuration.json placeholders into a temporary config before calling devopsmigration.